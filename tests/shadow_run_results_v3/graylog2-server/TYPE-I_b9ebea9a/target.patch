+    private static class NotEscapedCharMatcher extends CharMatcher {
+        private char lastChar = '\u0000';
+
+        @Override
+        public boolean matches(char c) {
+            if (lastChar == '\u0000') {
+                lastChar = c;
+                return true;
+            } else {
+                if (lastChar == '\\') {
+                    lastChar = c;
+                    return false;
+                } else {
+                    lastChar = c;
+                    return true;
+                }
+            }
+        }
+    }
