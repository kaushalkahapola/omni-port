+            INSERT INTO exp1 (id, doc)
+            VALUES
+                ('4', {"name" = [{ "a" = 1 }]}),
+                ('1', {"name" = { "a" = 1 }}),
+                ('2', {"name" = { "a" = 2 }}),
+                ('3', {"name" = { "a" = null }})
+            ;
+              """
+        );
+        execute("REFRESH TABLE exp1");
+        execute("SELECT id FROM exp1 order by id");
