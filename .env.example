# OmniPort Environment Configuration

# -------------------------------------------------------------
# Standard OpenAI Configuration (if using standard OpenAI)
# -------------------------------------------------------------
# OPENAI_API_KEY=sk-proj-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# -------------------------------------------------------------
# Azure OpenAI Configuration (if using Azure)
# -------------------------------------------------------------
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
OPENAI_API_VERSION=2024-02-15-preview

# -------------------------------------------------------------
# Model Tiering Configuration
# -------------------------------------------------------------
# If using Azure, these should match your DEPLOYMENT names
FAST_MODEL_NAME=gpt-4o-mini
BALANCED_MODEL_NAME=gpt-4o
REASONING_MODEL_NAME=o1-preview
